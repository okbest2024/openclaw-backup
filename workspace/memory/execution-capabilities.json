  "decisionRules": {
    "fallbackTrigger": {
      "errors": ["402", "429", "5xx", "timeout"],
      "minConsecutiveFailures": 2,
      "providerStatusCheck": true,
      "qualityThresholdBreach": true
    },
    "providerSelection": {
      "primary": "根据任务 providerPreference 顺序",
      "ifAllDown": "抛出错误 + 告警",
      "costOptimization": "优先免费/低成本 provider 满足质量要求"
    },
    "escalation": {
      "fallbackChainExhausted": "发送告警到 heartbeat + 记录到 provider-switch-log.md",
      "persistentFailures": "更新 heartbeat-state providerStatus 为 'degraded'",
      "qualityDrop": "触发 manual review"
    }
  },
  "implementationNotes": [
    "每个 cron 任务应引用其 execution-capabilities 条目",
    "executeWithFallback 接收 options 包含 taskCapabilities 用于智能选择",
