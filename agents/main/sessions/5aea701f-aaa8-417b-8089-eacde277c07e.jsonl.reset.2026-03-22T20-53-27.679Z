{"type":"message","id":"976dbba1","parentId":"c8cdf4fe","timestamp":"2026-03-22T11:00:14.995Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，网关正在运行（8080 端口有连接）。现在我需要创建一个看门狗监控脚本，它可以：\n1. 检查网关是否健康\n2. 如果不健康，自动重启\n\n让我创建一个 PowerShell 脚本作为看门狗，然后配置任务计划程序定期运行它。","thinkingSignature":"reasoning_content"},{"type":"text","text":"好的，网关正在运行！现在我来创建一个**独立看门狗监控脚本**，即使网关挂了也能自动重启：\n\n"},{"type":"toolCall","id":"call_355dcaa65e554744bf147e9d","name":"write","arguments":{"content":"# OpenClaw 看门狗监控脚本\n# 功能：检查网关健康状态，异常时自动重启\n# 部署位置：C:\\Users\\Administrator\\.openclaw\\workspace\\scripts\\watchdog.ps1\n\n$ErrorActionPreference = \"SilentlyContinue\"\n\n# 配置\n$GatewayPort = 8080\n$GatewayHost = \"localhost\"\n$HealthEndpoint = \"http://$GatewayHost:$GatewayPort/health\"\n$MaxRetries = 3\n$RetryDelay = 5 # 秒\n$LogFile = \"C:\\Users\\Administrator\\.openclaw\\workspace\\memory\\watchdog.log\"\n\n# 日志函数\nfunction Write-Log {\n    param($Message, $Level = \"INFO\")\n    $Timestamp = Get-Date -Format \"yyyy-MM-dd HH:mm:ss\"\n    $LogEntry = \"[$Timestamp] [$Level] $Message\"\n    Add-Content -Path $LogFile -Value $LogEntry\n    Write-Host $LogEntry\n}\n\n# 检查网关是否健康\nfunction Test-GatewayHealth {\n    try {\n        $response = Invoke-WebRequest -Uri $HealthEndpoint -TimeoutSec 10 -UseBasicParsing\n        return ($response.StatusCode -eq 200)\n    } catch {\n        return $false\n    }\n}\n\n# 检查网关进程是否存在\nfunction Test-GatewayProcess {\n    $processes = Get-Process -Name \"node\" -ErrorAction SilentlyContinue | \n        Where-Object {$_.Path -like \"*openclaw*\"}\n    return ($null -ne $processes -and $processes.Count -gt 0)\n}\n\n# 重启网关\nfunction Restart-Gateway {\n    Write-Log \"尝试重启网关...\" \"WARN\"\n    \n    # 停止现有进程\n    $processes = Get-Process -Name \"node\" -ErrorAction SilentlyContinue | \n        Where-Object {$_.Path -like \"*openclaw*\"}\n    if ($processes) {\n        $processes | Stop-Process -Force\n        Start-Sleep -Seconds 2\n        Write-Log \"已停止旧网关进程\" \"INFO\"\n    }\n    \n    # 启动新进程\n    try {\n        $workspacePath = \"C:\\Users\\Administrator\\.openclaw\\workspace\"\n        Start-Process -FilePath \"openclaw\" -ArgumentList \"gateway\", \"start\" -WorkingDirectory $workspacePath\n        Start-Sleep -Seconds 5\n        Write-Log \"已启动新网关进程\" \"INFO\"\n        return $true\n    } catch {\n        Write-Log \"启动网关失败：$_\" \"ERROR\"\n        return $false\n    }\n}\n\n# 主逻辑\nWrite-Log \"=== 看门狗检查开始 ===\"\n\n# 检查 1: 网关进程是否存在\n$processOk = Test-GatewayProcess\nWrite-Log \"网关进程状态：$(if($processOk){'运行中'}{'未运行'})\"\n\nif (-not $processOk) {\n    Write-Log \"网关进程未运行，尝试重启...\" \"WARN\"\n    Restart-Gateway\n    exit\n}\n\n# 检查 2: 端口是否监听\n$portCheck = netstat -ano | Select-String \":$GatewayPort\" | Select-String \"LISTENING\"\n$portOk = ($null -ne $portCheck)\nWrite-Log \"端口 $GatewayPort 状态：$(if($portOk){'监听中'}{'未监听'})\"\n\nif (-not $portOk) {\n    Write-Log \"网关端口未监听，尝试重启...\" \"WARN\"\n    Restart-Gateway\n    exit\n}\n\n# 检查 3: 健康检查端点\n$healthOk = Test-GatewayHealth\nWrite-Log \"健康检查端点：$(if($healthOk){'响应正常'}{'无响应'})\"\n\nif (-not $healthOk) {\n    Write-Log \"健康检查失败，尝试重启...\" \"WARN\"\n    \n    # 重试机制\n    $retryCount = 0\n    while ($retryCount -lt $MaxRetries) {\n        $retryCount++\n        Write-Log \"重试 $retryCount/$MaxRetries...\" \"INFO\"\n        Start-Sleep -Seconds $RetryDelay\n        \n        $healthOk = Test-GatewayHealth\n        if ($healthOk) {\n            Write-Log \"重试成功，网关恢复\" \"INFO\"\n            break\n        }\n    }\n    \n    if (-not $healthOk) {\n        Write-Log \"重试失败，强制重启网关...\" \"ERROR\"\n        Restart-Gateway\n    }\n}\n\nWrite-Log \"=== 看门狗检查完成 ===\"\n","path":"C:\\Users\\Administrator\\.openclaw\\workspace\\scripts\\watchdog.ps1"}}],"api":"openai-completions","provider":"bailian","model":"qwen3.5-plus","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774177184181}}
